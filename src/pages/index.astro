---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="lilPalette - AI Brand Color Palette Generator | lilAgents"
  description="Describe your business and get an AI-generated brand color palette with copyable hex codes and a downloadable mood board. A free tool by lilAgents."
>
  <section class="pt-12 pb-16 lg:pt-16 bg-white dark:bg-dark">
    <div class="container">
      <div id="palette-tool" class="mx-auto max-w-4xl">

        <header class="text-center mb-8">
          <h1 class="text-3xl sm:text-4xl font-bold text-dark dark:text-white mb-2">
            <span class="text-primary">lil</span>Palette
          </h1>
          <p class="text-body-color dark:text-dark-6">AI brand color palettes from a quick description of your business</p>
        </header>

        <!-- Form -->
        <div class="bg-white dark:bg-dark-2 rounded-2xl border border-gray-200 dark:border-dark-3 shadow-sm p-6 mb-8 max-w-2xl mx-auto">
          <h2 class="text-lg font-semibold text-dark dark:text-white mb-1">Tell us about your business</h2>
          <p class="text-sm text-body-color dark:text-dark-6 mb-5">A few details and we'll generate a color palette for your brand.</p>
          <form id="palette-form" class="space-y-5">
            <div>
              <label for="biz-name" class="block text-sm font-medium text-gray-700 mb-1">Business Name *</label>
              <input id="biz-name" type="text" required maxlength="100" placeholder="e.g., Sunrise Coffee Co." class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
            </div>
            <div>
              <label for="biz-tagline" class="block text-sm font-medium text-gray-700 mb-1">Tagline</label>
              <input id="biz-tagline" type="text" maxlength="200" placeholder="e.g., Where every cup tells a story" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
            </div>
            <div>
              <label for="biz-industry" class="block text-sm font-medium text-gray-700 mb-1">Industry &amp; Vibe *</label>
              <textarea id="biz-industry" required maxlength="300" rows="3" placeholder="e.g., coffee shop, cozy vibes, hospitality, modern, welcoming" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
            </div>
            <div>
              <button type="submit" id="generate-btn" class="w-full px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-blue-dark transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed">
                Generate Color Palette
              </button>
              <p id="remaining-uses" class="text-xs text-center text-body-color dark:text-dark-6 mt-2"></p>
            </div>
          </form>
        </div>

        <!-- Results -->
        <div id="palette-results" class="hidden space-y-8">
          <div class="bg-white dark:bg-dark-2 rounded-2xl border border-gray-200 dark:border-dark-3 shadow-sm p-6">
            <h2 class="text-lg font-semibold text-dark dark:text-white mb-4">Your brand colors</h2>
            <p class="text-sm text-body-color dark:text-dark-6 mb-5 text-center">Click any swatch to copy its hex code.</p>
            <div id="swatches" class="flex flex-wrap justify-center gap-6"></div>
          </div>

          <div class="bg-white dark:bg-dark-2 rounded-2xl border border-gray-200 dark:border-dark-3 shadow-sm p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold text-dark dark:text-white">Your brand mood board</h2>
              <button type="button" id="download-btn" class="px-4 py-2 bg-primary text-white rounded-lg font-medium hover:bg-blue-dark transition-colors duration-200">
                Download PNG
              </button>
            </div>
            <div class="flex justify-center bg-gray-1 dark:bg-dark rounded-lg p-4">
              <canvas id="moodboard-canvas" class="border border-gray-200 dark:border-dark-3 rounded-md max-w-full h-auto"></canvas>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Usage limit modal -->
  <div id="usage-modal" class="hidden fixed inset-0 z-[60] bg-black/70 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-dark-2 rounded-2xl shadow-xl max-w-lg w-full p-6">
      <h3 class="text-xl font-bold text-dark dark:text-white mb-3">Love the colors? Let's take it further</h3>
      <p class="text-body-color dark:text-dark-6 mb-6">We're so glad you're enjoying the tool. Want to upgrade to a free consultation and work with our expert designer?</p>
      <div class="flex flex-col-reverse sm:flex-row sm:justify-end gap-3">
        <button type="button" id="modal-later" class="px-5 py-2.5 rounded-lg font-medium bg-gray-1 dark:bg-dark text-dark dark:text-white hover:bg-gray-200 dark:hover:bg-dark-3 transition-colors">Maybe later</button>
        <a href="https://lilagents.com/#contact" class="px-5 py-2.5 rounded-lg font-medium bg-primary text-white hover:bg-blue-dark transition-colors text-center">Elevate your brand</a>
      </div>
    </div>
  </div>

  <style is:global>
    #palette-tool .swatch-item { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
    #palette-tool .swatch-box { width: 96px; height: 96px; border-radius: 0.5rem; border: 2px solid #e5e7eb; cursor: pointer; transition: transform 0.15s ease; padding: 0; }
    #palette-tool .swatch-box:hover { transform: scale(1.05); }
    #palette-tool .swatch-hex { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.75rem; color: var(--color-dark); }
    .dark #palette-tool .swatch-hex { color: #fff; }
    .dark #palette-tool .swatch-box { border-color: #374151; }
    #palette-tool .focus\:ring-blue-500:focus { --tw-ring-color: var(--color-primary); }
    #palette-tool .focus\:border-blue-500:focus { border-color: var(--color-primary); }
    .dark #palette-tool input,
    .dark #palette-tool textarea { background-color: var(--color-dark); border-color: #374151; color: #fff; }
    .dark #palette-tool .border-gray-300 { border-color: #374151; }
    .dark #palette-tool .text-gray-700 { color: #d1d5db; }
    .palette-toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--color-dark); color: #fff; padding: 10px 18px; border-radius: 9999px; font-size: 14px; opacity: 0; pointer-events: none; transition: opacity 0.2s ease, transform 0.2s ease; z-index: 70; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18); }
    .palette-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  </style>

  <script src="/tools/palette/app.js" is:inline></script>
</Layout>
